DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-secret-change-in-production-min-32-chars-long!!"
FRONTEND_ORIGIN="http://localhost:3000"
PORT=3001

# AI provider (optional): when OPENAI_API_KEY is set, backend will call OpenAI-compatible API.
# If not set, AI module falls back to local heuristic provider.
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o-mini"
